# Frontend environment variables (safe to expose in browser)
VITE_SUPABASE_URL=https://project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=public-anon-key
VITE_SUPABASE_REDIRECT_URL=http://localhost:5173/login
# Set to true to use the built-in mock Supabase client for offline/local testing
VITE_SUPABASE_USE_MOCK=false

# Backend-only keys - DO NOT put in this file!
# Use .env.supabase for SUPABASE_ACCESS_TOKEN and SUPABASE_SERVICE_ROLE_KEY
